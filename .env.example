# ── Transport ───────────────────────────────────────────────────────────────
# stdio | http   (the CLI flag --transport=<value> takes precedence over this)
MCP_TRANSPORT=stdio

# ── HTTP transport (used when MCP_TRANSPORT=http) ─────────────────────────────
HOST=127.0.0.1
PORT=3000

# Comma-separated Host header values accepted for DNS-rebinding protection.
# Leave empty to DISABLE the protection (only do this behind a trusted proxy).
ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated CORS origins for browser-based clients. Empty disables CORS.
CORS_ORIGINS=

# ── Bearer auth (HTTP transport, optional) ────────────────────────────────────
# true | false — when true, POST/GET/DELETE /mcp require a valid bearer token.
AUTH_ENABLED=false
# Comma-separated static tokens accepted by the example verifier.
# Replace src/core/auth.ts with real JWT/introspection for production.
AUTH_TOKENS=
# Comma-separated scopes every token must carry (empty = no scope requirement).
AUTH_REQUIRED_SCOPES=
# Optional Protected Resource Metadata URL advertised in 401 responses.
AUTH_RESOURCE_METADATA_URL=

# ── Logging ───────────────────────────────────────────────────────────────────
# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# development | test | production  (production emits plain JSON logs to stderr)
NODE_ENV=development
